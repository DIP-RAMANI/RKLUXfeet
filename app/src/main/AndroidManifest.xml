<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28"
        tools:ignore="ScopedStorage" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    
    <application
        android:name=".MyApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/logo1"
        android:label="@string/app_name"
        android:roundIcon="@drawable/logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.Androidhack">

        <!-- Main / Splash Screen (Launcher) -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Register Screen -->
        <activity
            android:name=".RegisterActivity"
            android:exported="false" />

        <!-- Login Screen -->
        <activity
            android:name=".LoginActivity"
            android:exported="false" />

        <!-- Forgot Password Screen -->
        <activity
            android:name=".ForgotPasswordActivity"
            android:exported="false" />

        <!-- Set New Password Screen -->
        <activity
            android:name=".SetNewPasswordActivity"
            android:exported="false" />

        <!-- Password Updated / Success Screen -->
        <activity
            android:name=".PasswordUpdatedActivity"
            android:exported="false" />

        <!-- Home, Store, and Wishlist Screens -->
        <activity
            android:name=".HomeActivity"
            android:exported="false" />
        <activity
            android:name=".StoreActivity"
            android:exported="false" />
        <activity
            android:name=".WishlistActivity"
            android:exported="false" />

        <!-- Profile and Settings Screens -->
        <activity
            android:name=".ProfileActivity"
            android:exported="false" />
        <activity
            android:name=".PersonalInformationActivity"
            android:exported="false" />
        <activity
            android:name=".AddressActivity"
            android:exported="false" />
        <activity
            android:name=".OrderHistoryActivity"
            android:exported="false" />
        <activity
            android:name=".PaymentMethodsActivity"
            android:exported="false" />

        <!-- E-commerce Flow Screens -->
        <activity
            android:name=".ProductDetailsActivity"
            android:exported="false" />
        <activity
            android:name=".CartActivity"
            android:exported="false" />
        <activity
            android:name=".CheckoutActivity"
            android:exported="false" />
        <activity
            android:name=".OrderDetailsActivity"
            android:exported="false" />

        <!-- Admin / Add Product -->
        <activity
            android:name=".AddProductActivity"
            android:exported="false" />

        <!-- Admin Panel Activities -->
        <activity android:name=".AdminDashboardActivity"  android:exported="false" />
        <activity android:name=".AdminUsersActivity"       android:exported="false" />
        <activity android:name=".AdminOrdersActivity"      android:exported="false" />
        <activity android:name=".AdminProductsActivity"    android:exported="false" />
        <activity android:name=".AdminAddProductActivity"  android:exported="false" />

        <!-- FileProvider for sharing PDF invoices -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
