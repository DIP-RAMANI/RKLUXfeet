<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top row: Type badge + Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvHistoryType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏷️ Offer"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_chip_active"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvHistoryTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2 hours ago"
                android:textColor="#9E9E9E"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tvHistoryTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notification Title"
            android:textColor="#1A1A2E"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <!-- Message -->
        <TextView
            android:id="@+id/tvHistoryMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notification message body"
            android:textColor="#757575"
            android:textSize="13sp"
            android:maxLines="3"
            android:ellipsize="end" />
    </LinearLayout>

</androidx.cardview.widget.CardView>
