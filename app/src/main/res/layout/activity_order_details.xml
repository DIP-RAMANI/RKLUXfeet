<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".OrderDetailsActivity">

    <!-- Header Frame -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clOrderDetailsHeader"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:background="@drawable/bg_home_header"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBackOrderDetails"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="24dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#000000"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvOrderDetailsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="Order Details"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/ivBackOrderDetails"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/ivBackOrderDetails" />

        <ImageView
            android:id="@+id/ivHelpOrderDetails"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="20dp"
            android:src="@drawable/ic_whatsapp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintBottom_toBottomOf="@id/ivBackOrderDetails"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/ivBackOrderDetails" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsvOrderDetailsContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/clOrderDetailsHeader"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="42dp">

            <!-- Order Info Section -->
            <TextView
                android:id="@+id/tvOrderId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Order #..."
                android:textColor="#000000"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvOrderDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="March 28, 2026 at 12:43 AM"
                android:textColor="#757575"
                android:textSize="13sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp" />

            <!-- Order Status Banner -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:text="Order Tracking"
                            android:textColor="#000000"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvOrderStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="Pending"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:background="@drawable/bg_chip_active"
                            android:backgroundTint="#FFB300" />
                    </RelativeLayout>

                    <!-- Step 1: Order Placed -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <LinearLayout android:layout_width="28dp" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center_horizontal">
                            <ImageView android:id="@+id/ivStep1" android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_check" android:background="@drawable/bg_step_active" android:padding="6dp" app:tint="#FFFFFF" />
                            <View android:id="@+id/lineStep1" android:layout_width="3dp" android:layout_height="36dp" android:background="#E0E0E0" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp" android:layout_marginTop="2dp">
                            <TextView android:id="@+id/tvStep1Title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Order Placed" android:textColor="#000000" android:textSize="14sp" android:textStyle="bold" />
                            <TextView android:id="@+id/tvStep1Time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#757575" android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Step 2: Confirmed -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <LinearLayout android:layout_width="28dp" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center_horizontal">
                            <ImageView android:id="@+id/ivStep2" android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_check" android:background="@drawable/bg_step_inactive" android:padding="6dp" app:tint="#E0E0E0" />
                            <View android:id="@+id/lineStep2" android:layout_width="3dp" android:layout_height="36dp" android:background="#E0E0E0" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp" android:layout_marginTop="2dp">
                            <TextView android:id="@+id/tvStep2Title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Confirmed" android:textColor="#BDBDBD" android:textSize="14sp" />
                            <TextView android:id="@+id/tvStep2Time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#757575" android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Step 3: Shipped -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <LinearLayout android:layout_width="28dp" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center_horizontal">
                            <ImageView android:id="@+id/ivStep3" android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_check" android:background="@drawable/bg_step_inactive" android:padding="6dp" app:tint="#E0E0E0" />
                            <View android:id="@+id/lineStep3" android:layout_width="3dp" android:layout_height="36dp" android:background="#E0E0E0" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp" android:layout_marginTop="2dp">
                            <TextView android:id="@+id/tvStep3Title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Shipped" android:textColor="#BDBDBD" android:textSize="14sp" />
                            <TextView android:id="@+id/tvStep3Time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#757575" android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Step 4: Out for Delivery -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <LinearLayout android:layout_width="28dp" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center_horizontal">
                            <ImageView android:id="@+id/ivStep4" android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_check" android:background="@drawable/bg_step_inactive" android:padding="6dp" app:tint="#E0E0E0" />
                            <View android:id="@+id/lineStep4" android:layout_width="3dp" android:layout_height="36dp" android:background="#E0E0E0" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp" android:layout_marginTop="2dp">
                            <TextView android:id="@+id/tvStep4Title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Out for Delivery" android:textColor="#BDBDBD" android:textSize="14sp" />
                            <TextView android:id="@+id/tvStep4Time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#757575" android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Step 5: Delivered -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <LinearLayout android:layout_width="28dp" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center_horizontal">
                            <ImageView android:id="@+id/ivStep5" android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_check" android:background="@drawable/bg_step_inactive" android:padding="6dp" app:tint="#E0E0E0" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp" android:layout_marginTop="2dp">
                            <TextView android:id="@+id/tvStep5Title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Delivered" android:textColor="#BDBDBD" android:textSize="14sp" />
                            <TextView android:id="@+id/tvStep5Time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#757575" android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Tracking Info Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvTrackingInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="24dp"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📦 Tracking Information" android:textColor="#000000" android:textSize="15sp" android:textStyle="bold" android:layout_marginBottom="10dp" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Courier: " android:textColor="#757575" android:textSize="13sp" />
                        <TextView android:id="@+id/tvCourierName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="#000000" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tracking #: " android:textColor="#757575" android:textSize="13sp" />
                        <TextView android:id="@+id/tvTrackingNumber" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="#7C4DFF" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Items -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Items Ordered"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvOrderDetailsItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_order_detail" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <!-- Promo Code Applied Row (hidden if no promo) -->
            <RelativeLayout
                android:id="@+id/rlOrderPromoRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Promo Applied 🎟️"
                        android:textColor="#43A047"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvOrderPromoCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CODE"
                        android:textColor="#757575"
                        android:textSize="12sp" />
                </LinearLayout>
                <TextView
                    android:id="@+id/tvOrderPromoDiscount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="-₹0"
                    android:textColor="#43A047"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="16dp" />

            <!-- Total Amount -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:text="Total Amount"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvOrderTotalAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="₹0"
                    android:textColor="#43A047"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- Addresses & Payment -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Shipping Address"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvShippingAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="..."
                android:textColor="#757575"
                android:textSize="14sp"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Payment Method"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="42dp">

                <ImageView
                    android:id="@+id/ivPaymentMethodIcon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_card"
                    android:scaleType="centerInside"
                    app:tint="#7C4DFF"/>

                <TextView
                    android:id="@+id/tvPaymentMethod"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="..."
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginStart="16dp" />
            </LinearLayout>

            <!-- Action Buttons Footer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnDownloadInvoice"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_button"
                    android:text="📄 Download"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textAllCaps="false" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnEmailInvoice"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_violet"
                    android:text="📧 Email Invoice"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textAllCaps="false" />

            </LinearLayout>

            <!-- Rate Product button — visible only for Delivered orders -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnRateProduct"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_button_yellow"
                android:text="⭐ Rate your Purchase"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:visibility="gone" />

            <!-- Return / Exchange button — visible only for Delivered orders -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnReturnExchange"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_size_chip_unselected"
                android:text="↩ Return / Exchange"
                android:textColor="#E53935"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:visibility="gone" />

            <!-- Return Request Status card — shown if request already submitted -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvReturnStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFF3E0">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="↩ Return / Exchange Request"
                        android:textColor="#E65100"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:id="@+id/tvReturnStatusDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Status: Pending Review"
                        android:textColor="#757575"
                        android:textSize="13sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

