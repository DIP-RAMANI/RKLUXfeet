<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Top Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:paddingHorizontal="20dp">
        <ImageView
            android:id="@+id/ivAddProductBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_arrow_back"
            app:tint="#1A1A2E" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Add New Product"
            android:textColor="#1A1A2E"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Product Name *" android:textColor="#000000" android:textStyle="bold" android:layout_marginBottom="6dp" />
            <EditText
                android:id="@+id/etAdminProductName"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="#F5F5F5"
                android:hint="e.g. Nike Air Max 2025"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="20dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Price *" android:textColor="#000000" android:textStyle="bold" android:layout_marginBottom="6dp" />
            <EditText
                android:id="@+id/etAdminProductPrice"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="#F5F5F5"
                android:hint="e.g. ₹2999"
                android:paddingHorizontal="16dp"
                android:inputType="numberDecimal"
                android:layout_marginBottom="20dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Product Story" android:textColor="#000000" android:textStyle="bold" android:layout_marginBottom="6dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="A narrative about the shoe (what it's built for, technology used)" android:textColor="#9E9E9E" android:textSize="11sp" android:layout_marginBottom="4dp" />
            <EditText
                android:id="@+id/etAdminProductStory"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="#F5F5F5"
                android:hint="e.g. The Conduct Pro shoes are built for runners who want energy with every step. Powered by PROFOAM cushioning..."
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:gravity="top"
                android:layout_marginBottom="20dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Features &amp; Benefits" android:textColor="#000000" android:textStyle="bold" android:layout_marginBottom="6dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Enter each feature on a new line" android:textColor="#9E9E9E" android:textSize="11sp" android:layout_marginBottom="4dp" />
            <EditText
                android:id="@+id/etAdminProductFeatures"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="#F5F5F5"
                android:hint="e.g.&#10;PROFOAM: Lightweight EVA for responsive cushioning&#10;PROPLATE: Added support with bold design impact&#10;SoftFoam+: Step in comfort and long lasting cushioning"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:gravity="top"
                android:layout_marginBottom="20dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Details" android:textColor="#000000" android:textStyle="bold" android:layout_marginBottom="6dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Enter each detail on a new line (e.g. Upper: Mesh, Closure: Laces)" android:textColor="#9E9E9E" android:textSize="11sp" android:layout_marginBottom="4dp" />
            <EditText
                android:id="@+id/etAdminProductDetails"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="#F5F5F5"
                android:hint="e.g.&#10;Upper: Bootie construction with 2-tone material depth&#10;Outsole: PROTREAD full rubber coverage&#10;Closure: Laces&#10;Fit: Regular&#10;Toe: Rounded"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:gravity="top"
                android:layout_marginBottom="20dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Brand" android:textColor="#000000" android:textStyle="bold" android:layout_marginBottom="6dp" />
            <EditText
                android:id="@+id/etAdminProductBrand"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="#F5F5F5"
                android:hint="e.g. Nike, Adidas, Puma, Asics"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="20dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Shoe Type *" android:textColor="#000000" android:textStyle="bold" android:layout_marginBottom="6dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Select the category for this shoe" android:textColor="#9E9E9E" android:textSize="11sp" android:layout_marginBottom="4dp" />
            <Spinner
                android:id="@+id/spShoeType"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="#F5F5F5"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="20dp" />

            <Switch
                android:id="@+id/swInStock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="In Stock"
                android:textColor="#000000"
                android:textStyle="bold"
                android:checked="true"
                android:layout_marginBottom="20dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Discount % (optional, e.g. 20 for 20% off)" android:textColor="#000000" android:textStyle="bold" android:layout_marginBottom="6dp" />
            <EditText
                android:id="@+id/etAdminProductDiscount"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="#F5F5F5"
                android:hint="0 = no discount"
                android:paddingHorizontal="16dp"
                android:inputType="number"
                android:layout_marginBottom="20dp" />

            <!-- Image Section -->
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginBottom="20dp" />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Product Images (min 2, max 4)"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📌 Image 1 and Image 2 are required"
                android:textColor="#E53935"
                android:textSize="12sp"
                android:layout_marginBottom="16dp" />

            <!-- IMAGE SLOT 1 (required) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Image 1 * (required)"
                android:textColor="#1A1A2E"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />
            <ImageView
                android:id="@+id/ivPreview1"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:scaleType="centerCrop"
                android:background="#F0F0F0"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">
                <Button
                    android:id="@+id/btnPickImage1"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="📷 Pick"
                    android:textAllCaps="false"
                    android:backgroundTint="#1A1A2E"
                    android:layout_marginEnd="8dp" />
                <Button
                    android:id="@+id/btnRemoveImage1"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="✕"
                    android:textAllCaps="false"
                    android:backgroundTint="#E53935"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- IMAGE SLOT 2 (required) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Image 2 * (required)"
                android:textColor="#1A1A2E"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />
            <ImageView
                android:id="@+id/ivPreview2"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:scaleType="centerCrop"
                android:background="#F0F0F0"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">
                <Button
                    android:id="@+id/btnPickImage2"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="📷 Pick"
                    android:textAllCaps="false"
                    android:backgroundTint="#1A1A2E"
                    android:layout_marginEnd="8dp" />
                <Button
                    android:id="@+id/btnRemoveImage2"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="✕"
                    android:textAllCaps="false"
                    android:backgroundTint="#E53935"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- VIDEO SLOT 3 (optional) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Video (optional, slot 3)"
                android:textColor="#757575"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />
            <ImageView
                android:id="@+id/ivPreview3"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:scaleType="centerCrop"
                android:background="#F0F0F0"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">
                <Button
                    android:id="@+id/btnPickImage3"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="🎥 Pick Video"
                    android:textAllCaps="false"
                    android:backgroundTint="#5C6BC0"
                    android:layout_marginEnd="8dp" />
                <Button
                    android:id="@+id/btnRemoveImage3"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="✕"
                    android:textAllCaps="false"
                    android:backgroundTint="#E53935"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- IMAGE SLOT 4 (optional) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Image 4 (optional)"
                android:textColor="#757575"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />
            <ImageView
                android:id="@+id/ivPreview4"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:scaleType="centerCrop"
                android:background="#F0F0F0"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp">
                <Button
                    android:id="@+id/btnPickImage4"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="📷 Pick"
                    android:textAllCaps="false"
                    android:backgroundTint="#5C6BC0"
                    android:layout_marginEnd="8dp" />
                <Button
                    android:id="@+id/btnRemoveImage4"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="✕"
                    android:textAllCaps="false"
                    android:backgroundTint="#E53935"
                    android:visibility="gone" />
            </LinearLayout>

            <Button
                android:id="@+id/btnSaveAdminProduct"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="✅  Save Product"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:backgroundTint="#43A047" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
