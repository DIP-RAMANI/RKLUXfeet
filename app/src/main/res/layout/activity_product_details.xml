<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".ProductDetailsActivity">

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="88dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ═══════════════════════════════════════════ -->
            <!-- IMAGE AREA with ViewPager2 + dots            -->
            <!-- ═══════════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="340dp"
                android:layout_margin="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                <!-- Scrollable image pager -->
                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/vpProductImages"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal" />

                <!-- Back button - floating over pager -->
                <ImageView
                    android:id="@+id/ivBackProduct"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_margin="16dp"
                    android:background="@drawable/bg_circle"
                    android:padding="8dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="#000000" />

                <!-- Wishlist Heart - top right -->
                <ImageView
                    android:id="@+id/ivWishlistHeart"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="16dp"
                    android:background="@drawable/bg_circle"
                    android:padding="8dp"
                    android:src="@drawable/ic_wishlist"
                    app:tint="#CCCCCC" />

                <!-- In Stock badge -->
                <TextView
                    android:id="@+id/tvStockStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|start"
                    android:layout_margin="16dp"
                    android:background="#43A047"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="● In Stock"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <!-- Dot indicators bottom-center -->
                <LinearLayout
                    android:id="@+id/llImageDots"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal"
                    android:gravity="center" />

                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══════════════════════════════════════════ -->
            <!-- PRODUCT INFO CARD                            -->
            <!-- ═══════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp">

                <!-- Name + Rating Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvProductName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Product Name"
                        android:textColor="#000000"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <!-- Rating pill -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip_active"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐ "
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvProductRating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4.5"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Delivery info -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="📦 Free delivery in 2-3 days"
                    android:textColor="#757575"
                    android:textSize="13sp" />

                <!-- Description -->
                <TextView
                    android:id="@+id/tvProductDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:lineSpacingExtra="4dp"
                    android:text="No description available."
                    android:textColor="#555555"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- ═══════════════════════════════════════════ -->
            <!-- SIZE SELECTOR                                -->
            <!-- ═══════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Size 👟"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btnSize6"
                        android:layout_width="52dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_size_chip_unselected"
                        android:gravity="center"
                        android:text="UK 6"
                        android:textColor="#000000"
                        android:textSize="13sp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/btnSize7"
                        android:layout_width="52dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_size_chip_selected"
                        android:gravity="center"
                        android:text="UK 7"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/btnSize8"
                        android:layout_width="52dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_size_chip_unselected"
                        android:gravity="center"
                        android:text="UK 8"
                        android:textColor="#000000"
                        android:textSize="13sp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/btnSize9"
                        android:layout_width="52dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_size_chip_unselected"
                        android:gravity="center"
                        android:text="UK 9"
                        android:textColor="#000000"
                        android:textSize="13sp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/btnSize10"
                        android:layout_width="52dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_size_chip_unselected"
                        android:gravity="center"
                        android:text="UK 10"
                        android:textColor="#000000"
                        android:textSize="13sp"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>
            </LinearLayout>

            <!-- ═══════════════════════════════════════════ -->
            <!-- PRODUCT STORY                               -->
            <!-- ═══════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/llProductStory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PRODUCT STORY"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <View
                    android:layout_width="40dp"
                    android:layout_height="3dp"
                    android:background="#7C4DFF"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvProductStory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="5dp"
                    android:textColor="#555555"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- ═══════════════════════════════════════════ -->
            <!-- FEATURES & BENEFITS + DETAILS              -->
            <!-- ═══════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/llFeaturesDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp"
                android:visibility="gone">

                <!-- Features & Benefits -->
                <LinearLayout
                    android:id="@+id/llFeatures"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="20dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FEATURES &amp; BENEFITS"
                        android:textColor="#000000"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <View
                        android:layout_width="40dp"
                        android:layout_height="3dp"
                        android:background="#7C4DFF"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvProductFeatures"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="6dp"
                        android:textColor="#555555"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Details -->
                <LinearLayout
                    android:id="@+id/llDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DETAILS"
                        android:textColor="#000000"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <View
                        android:layout_width="40dp"
                        android:layout_height="3dp"
                        android:background="#7C4DFF"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvProductDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="6dp"
                        android:textColor="#555555"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ═══════════════════════════════════════════ -->
            <!-- SPECIFICATIONS (legacy, kept for old data) -->
            <!-- ═══════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/llSpecs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Specifications"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvProductSpecs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:lineSpacingExtra="6dp"
                    android:text="• Sole: Rubber\n• Upper: Mesh + Synthetic\n• Outsole: Rubber"
                    android:textColor="#555555"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- ═══════════════════════════════════════════ -->
            <!-- PRICE SECTION                                -->
            <!-- ═══════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Price"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvProductPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹2,699"
                        android:textColor="#43A047"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvProductOriginalPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="₹3,499"
                        android:textColor="#757575"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tvDiscount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="#FFEBEE"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:text="-23%"
                        android:textColor="#E53935"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ═══════════════════════════════════════════ -->
    <!-- STICKY BOTTOM ACTION BAR                    -->
    <!-- ═══════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:elevation="12dp"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="20dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnAddToCart"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_button_violet"
            android:text="Add to Cart"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="false" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnBuyNow"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_violet"
            android:text="Buy Now"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="false" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
