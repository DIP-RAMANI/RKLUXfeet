<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Base Image -->
    <ImageView
        android:id="@+id/ivBannerSlide"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

    <!-- Dark Gradient Overlay for text readability -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#40000000" />

    <!-- Text Overlays -->
    <TextView
        android:id="@+id/tvBannerTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Summer Collection \uD83D\uDD25"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginStart="20dp"
        app:layout_constraintBottom_toTopOf="@+id/tvBannerDiscount"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvBannerDiscount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Up to 40% OFF"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@+id/tvBannerTitle" />

</androidx.constraintlayout.widget.ConstraintLayout>
