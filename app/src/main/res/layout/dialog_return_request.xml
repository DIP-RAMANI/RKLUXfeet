<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingHorizontal="24dp"
    android:paddingTop="16dp"
    android:paddingBottom="32dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="#DDDDDD"
        android:backgroundTint="#DDDDDD" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="↩ Return / Exchange"
        android:textColor="#1A1A1A"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tell us what you'd like to do and why."
        android:textColor="#757575"
        android:textSize="13sp"
        android:layout_marginBottom="24dp" />

    <!-- Request Type -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Request Type"
        android:textColor="#1A1A1A"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/btnTypeReturn"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:gravity="center"
            android:text="↩ Return"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#7C4DFF"
            android:background="@drawable/bg_size_chip_selected"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnTypeExchange"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🔄 Exchange"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#424242"
            android:background="@drawable/bg_size_chip_unselected"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Reason -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reason"
        android:textColor="#1A1A1A"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/reasonWrongSize"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:gravity="center"
                android:text="Wrong Size"
                android:textSize="12sp"
                android:textColor="#424242"
                android:background="@drawable/bg_size_chip_unselected"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/reasonDefective"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:gravity="center"
                android:text="Defective"
                android:textSize="12sp"
                android:textColor="#424242"
                android:background="@drawable/bg_size_chip_unselected"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/reasonNotAsDesc"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Not as Described"
                android:textSize="11sp"
                android:textColor="#424242"
                android:background="@drawable/bg_size_chip_unselected"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/reasonChanged"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:gravity="center"
                android:text="Changed Mind"
                android:textSize="12sp"
                android:textColor="#424242"
                android:background="@drawable/bg_size_chip_unselected"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/reasonOther"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Other"
                android:textSize="12sp"
                android:textColor="#424242"
                android:background="@drawable/bg_size_chip_unselected"
                android:clickable="true"
                android:focusable="true" />

            <!-- spacer -->
            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        </LinearLayout>
    </LinearLayout>

    <!-- Additional Notes -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Additional Notes (optional)"
        android:textColor="#1A1A1A"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etReturnNotes"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:hint="Describe your issue..."
        android:textSize="14sp"
        android:textColor="#1A1A1A"
        android:textColorHint="#BDBDBD"
        android:background="@drawable/bg_size_chip_unselected"
        android:padding="14dp"
        android:gravity="top|start"
        android:inputType="textMultiLine"
        android:maxLines="4"
        android:layout_marginBottom="24dp" />

    <!-- Submit Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnSubmitReturn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_button_violet"
        android:text="Submit Request"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textAllCaps="false" />

</LinearLayout>
