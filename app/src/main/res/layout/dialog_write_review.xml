<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:padding="24dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_chip_inactive" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⭐ Write a Review"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Share your experience with this product"
        android:textSize="13sp"
        android:textColor="#757575"
        android:layout_marginBottom="20dp" />

    <!-- Star Rating -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Rating"
        android:textSize="14sp"
        android:textColor="#424242"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <RatingBar
        android:id="@+id/rbReviewRating"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:numStars="5"
        android:stepSize="1"
        android:rating="5"
        android:progressTint="#FFB300"
        android:progressBackgroundTint="#E0E0E0"
        android:layout_marginBottom="20dp"
        style="?android:attr/ratingBarStyle" />

    <!-- Comment -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Review"
        android:textSize="14sp"
        android:textColor="#424242"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etReviewComment"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="@drawable/bg_rounded_input"
        android:gravity="top|start"
        android:hint="Tell us what you liked or didn't like..."
        android:inputType="textMultiLine"
        android:padding="14dp"
        android:textColor="#212121"
        android:textColorHint="#BDBDBD"
        android:textSize="14sp"
        android:layout_marginBottom="20dp" />

    <!-- Submit Button -->
    <TextView
        android:id="@+id/btnSubmitReview"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:gravity="center"
        android:text="Submit Review"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_brand_tab_active" />

</LinearLayout>
