<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F7FF"
    tools:context=".AdminProductsActivity">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clProductsHeader"
        android:layout_width="match_parent"
        android:layout_height="130dp"
        android:background="#7C4DFF"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivProductsBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="40dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/ivProductsBack"
            app:layout_constraintTop_toTopOf="@id/ivProductsBack"
            app:layout_constraintBottom_toBottomOf="@id/ivProductsBack"
            app:layout_constraintEnd_toStartOf="@id/tvAddProduct">

            <TextView
                android:id="@+id/tvProductsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage Products"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add, edit or remove listings"
                android:textColor="#E8E0FF"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvAddProduct"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="16dp"
            android:text="+ Add"
            android:gravity="center"
            android:textColor="#7C4DFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/bg_chip_inactive"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintBottom_toBottomOf="@id/ivProductsBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/ivProductsBack" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Floating Search Bar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvProductsSearch"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="-26dp"
        app:cardCornerRadius="26dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/clProductsHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                app:tint="#7C4DFF" />
            <EditText
                android:id="@+id/etProductsSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:hint="Search products..."
                android:textColor="#212121"
                android:textColorHint="#9E9E9E"
                android:textSize="14sp"
                android:layout_marginStart="10dp"
                android:singleLine="true"
                android:imeOptions="actionSearch" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Products List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAdminProducts"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="8dp"
        android:clipToPadding="false"
        android:paddingBottom="84dp"
        app:layout_constraintTop_toBottomOf="@id/cvProductsSearch"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- FAB Add -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddProduct"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:backgroundTint="#7C4DFF"
        app:tint="#FFFFFF"
        app:srcCompat="@android:drawable/ic_input_add"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
