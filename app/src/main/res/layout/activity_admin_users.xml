<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".AdminUsersActivity">

    <!-- Header Frame -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clUsersHeader"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="@drawable/bg_home_header"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivUsersBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="32dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#000000"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvUsersTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:fontFamily="sans-serif-black"
            android:text="All Users"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/ivUsersBack"
            app:layout_constraintStart_toEndOf="@id/ivUsersBack"
            app:layout_constraintTop_toTopOf="@id/ivUsersBack" />

        <TextView
            android:id="@+id/tvUserCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="20dp"
            android:text="0 users"
            android:textColor="#555555"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/ivUsersBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/ivUsersBack" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Search Bar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvUsersSearch"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginHorizontal="20dp"
        app:cardCornerRadius="25dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/clUsersHeader"
        android:layout_marginTop="-25dp">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                app:tint="#8D8D8D"/>
            <EditText
                android:id="@+id/etUsersSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:hint="Search users..."
                android:textColor="#000000"
                android:textColorHint="#8D8D8D"
                android:textSize="14sp"
                android:layout_marginStart="10dp"
                android:singleLine="true"
                android:imeOptions="actionSearch" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Filter Chips Row -->
    <HorizontalScrollView
        android:id="@+id/hsvUsersFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/cvUsersSearch">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:gravity="center_vertical">

            <TextView android:id="@+id/chipFilterAll"     android:layout_width="wrap_content" android:layout_height="36dp" android:text="All"         android:gravity="center" android:paddingHorizontal="18dp" android:textSize="13sp" android:background="@drawable/bg_chip_active"   android:textColor="#FFFFFF" android:layout_marginEnd="8dp" />
            <TextView android:id="@+id/chipFilterActive"  android:layout_width="wrap_content" android:layout_height="36dp" android:text="Active"      android:gravity="center" android:paddingHorizontal="18dp" android:textSize="13sp" android:background="@drawable/bg_chip_inactive" android:textColor="#000000" android:layout_marginEnd="8dp" />
            <TextView android:id="@+id/chipFilterBlocked" android:layout_width="wrap_content" android:layout_height="36dp" android:text="Blocked"     android:gravity="center" android:paddingHorizontal="18dp" android:textSize="13sp" android:background="@drawable/bg_chip_inactive" android:textColor="#000000" android:layout_marginEnd="8dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- User List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvUsers"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="8dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toBottomOf="@id/hsvUsersFilter"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
