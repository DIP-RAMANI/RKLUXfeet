<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".WishlistActivity">

    <!-- Top App Bar Area -->
    <RelativeLayout
        android:id="@+id/rlAppBarWishlist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBackWishlist"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_arrow_back"
            app:tint="#000000" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="sans-serif-black"
            android:text="Wishlist"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold" />
            
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true">
            <ImageView
                android:id="@+id/ivCart"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_bag" />
            <TextView
                android:id="@+id/tvCartBadge"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:background="@drawable/bg_badge_red"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:gravity="center"
                android:visibility="gone"
                android:elevation="4dp"
                android:translationX="6dp"
                android:translationY="-6dp"
                android:layout_alignTop="@id/ivCart"
                android:layout_alignEnd="@id/ivCart" />
        </RelativeLayout>
    </RelativeLayout>
    
    <TextView
        android:id="@+id/tvWishlistEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Wishlist is Empty!"
        android:textColor="#8D8D8D"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rlAppBarWishlist" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvWishlistGrid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:spanCount="2"
        app:layout_constraintTop_toBottomOf="@id/rlAppBarWishlist"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        tools:listitem="@layout/item_shoe_grid" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_bottom_nav_dark"
        app:tabIndicator="@drawable/tab_indicator_dash"
        app:tabIndicatorGravity="top"
        app:tabIconTint="@color/tab_icon_color"
        app:tabRippleColor="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:elevation="12dp">

        <com.google.android.material.tabs.TabItem
            android:icon="@drawable/ic_home" />
        <com.google.android.material.tabs.TabItem
            android:icon="@drawable/ic_shop" />
        <com.google.android.material.tabs.TabItem
            android:icon="@drawable/ic_wishlist" />
        <com.google.android.material.tabs.TabItem
            android:icon="@drawable/ic_profile" />
    </com.google.android.material.tabs.TabLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
